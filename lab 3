    print()
    
    # ===== 3. INTERPRETER =====
    print("3. INTERPRETER (Інтерпретатор)")
    context = {"x": 10, "y": 5}
    expression = AddExpression(
        NumberExpression(5),
        SubtractExpression(
            VariableExpression("x"),
            VariableExpression("y")
        )
    )
    result = expression.interpret(context)
    print(f"   Результат виразу 5 + (x - y) = {result} (де x=10, y=5)\n")
    
    # ===== 4. ITERATOR =====
