# 10. TEMPLATE METHOD (Шаблонний метод)
# ============================================================
class DataProcessor(ABC):
    def process(self):
        self.load_data()
        self.analyze_data()
        self.save_results()
        self.generate_report()
    
    @abstractmethod
    def load_data(self):
        pass
    
    @abstractmethod
    def analyze_data(self):
        pass
    
    def save_results(self):
        print("  💾 Результати збережено")
    
    def generate_report(self):
        print("  📊 Звіт згенеровано")

class CSVProcessor(DataProcessor):
    def load_data(self):
        print("  📂 Завантажено CSV файл")
    
    def analyze_data(self):
        print("  🔍 Аналіз CSV даних")

class JSONProcessor(DataProcessor):
    def load_data(self):
        print("  📂 Завантажено JSON файл")
    
    def analyze_data(self):
        print("  🔍 Аналіз JSON даних")


