    # ===== 6. MEMENTO =====
    print("6. MEMENTO (Хранитель)")
    editor = Editor()
    history = History()
    
    editor.type("Привіт ")
    history.push(editor.save())
    editor.type("Світ!")
    history.push(editor.save())
    
    print(f"   Поточний текст: {editor.get_content()}")
    editor.restore(history.pop())
    print(f"   Після undo: {editor.get_content()}")
